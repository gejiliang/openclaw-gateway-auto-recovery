# OpenClaw Mini production recovery adapter for Gateway v0.4.x governance.
# This directory is prepared offline and is not wired into the live Gateway yet.

: "${OPENCLAW_PROFILE:=default}"
: "${OPENCLAW_STATE_DIR:=$HOME/.openclaw}"
: "${RECOVERY_ROOT:=$HOME/.openclaw/recovery/gateway-v04}"

: "${SERVICE_LABEL:=ai.openclaw.gateway}"
: "${CLI_BIN:=/path/to/openclaw}"
: "${LAUNCHCTL_BIN:=/bin/launchctl}"
: "${LSOF_BIN:=/usr/sbin/lsof}"
: "${STAT_BIN:=/usr/bin/stat}"
: "${TAIL_BIN:=/usr/bin/tail}"
: "${DATE_BIN:=/bin/date}"
: "${HOSTNAME_BIN:=/bin/hostname}"

: "${GATEWAY_PORT:=18789}"
: "${GATEWAY_BIND:=lan}"
: "${GATEWAY_LOG:=$HOME/.openclaw/logs/gateway.log}"
: "${GATEWAY_ERR_LOG:=$HOME/.openclaw/logs/gateway.err.log}"
: "${CLI_FILE_LOG_DIR:=/tmp/openclaw}"

: "${ADAPTER_BIN_DIR:=$HOME/.openclaw/recovery/gateway-v04/bin}"
: "${RESULT_FILE:=$HOME/.openclaw/recovery/gateway-v04/results/last-result.json}"
: "${EVENT_FILE:=$HOME/.openclaw/recovery/gateway-v04/logs/recover-events.log}"
: "${ATTEMPT_LOG:=$HOME/.openclaw/recovery/gateway-v04/logs/recover-attempts.log}"
: "${SAMPLES_DIR:=$HOME/.openclaw/recovery/gateway-v04/samples}"
: "${LOCK_DIR:=$HOME/.openclaw/recovery/gateway-v04/locks/recover.lock}"

: "${RECOVER_COOLDOWN_SECONDS:=60}"
: "${RECOVER_MAX_RECENT_ATTEMPTS:=3}"
: "${RECOVER_WINDOW_SECONDS:=300}"
: "${RECOVER_LOCK_STALE_SECONDS:=600}"
: "${RECOVER_LOG_TAIL_LINES:=120}"

: "${AUTO_ACP_ENABLED:=0}"
: "${AUTO_ACP_AGENT_ID:=codex}"
: "${AUTO_ACP_MODE:=run}"
: "${AUTO_ACP_THREAD:=0}"
: "${AUTO_ACP_COOLDOWN_SECONDS:=1800}"
: "${AUTO_ACP_MAX_RECENT_ATTEMPTS:=1}"
: "${AUTO_ACP_WINDOW_SECONDS:=21600}"
: "${AUTO_ACP_REQUEST_DIR:=$HOME/.openclaw/recovery/gateway-v04/state/auto-acp}"
: "${AUTO_ACP_BRIDGE_MODE:=acpx}"
: "${AUTO_ACP_ACPX_CMD:=/path/to/plugin-local/acpx}"
: "${AUTO_ACP_CODEX_CMD:=codex}"
: "${AUTO_ACP_CWD:=$HOME/.openclaw/recovery/gateway-v04}"
: "${AUTO_ACP_TIMEOUT_SECONDS:=900}"
: "${TIMEOUT_BIN:=}"

export OPENCLAW_PROFILE OPENCLAW_STATE_DIR RECOVERY_ROOT SERVICE_LABEL CLI_BIN LAUNCHCTL_BIN LSOF_BIN STAT_BIN TAIL_BIN DATE_BIN HOSTNAME_BIN TIMEOUT_BIN
export GATEWAY_PORT GATEWAY_BIND GATEWAY_LOG GATEWAY_ERR_LOG CLI_FILE_LOG_DIR ADAPTER_BIN_DIR RESULT_FILE EVENT_FILE ATTEMPT_LOG SAMPLES_DIR LOCK_DIR
export RECOVER_COOLDOWN_SECONDS RECOVER_MAX_RECENT_ATTEMPTS RECOVER_WINDOW_SECONDS RECOVER_LOCK_STALE_SECONDS RECOVER_LOG_TAIL_LINES
export AUTO_ACP_ENABLED AUTO_ACP_AGENT_ID AUTO_ACP_MODE AUTO_ACP_THREAD AUTO_ACP_COOLDOWN_SECONDS AUTO_ACP_MAX_RECENT_ATTEMPTS AUTO_ACP_WINDOW_SECONDS AUTO_ACP_REQUEST_DIR AUTO_ACP_BRIDGE_MODE AUTO_ACP_ACPX_CMD AUTO_ACP_CODEX_CMD AUTO_ACP_CWD AUTO_ACP_TIMEOUT_SECONDS
