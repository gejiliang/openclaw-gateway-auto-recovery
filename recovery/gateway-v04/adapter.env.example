# Example adapter.env for OpenClaw Gateway external auto-recovery
# Copy to adapter.env and adjust for your machine.

OPENCLAW_PROFILE="default"
OPENCLAW_STATE_DIR="$HOME/.openclaw"
RECOVERY_ROOT="$HOME/.openclaw/recovery/gateway-v04"

SERVICE_LABEL="ai.openclaw.gateway"
CLI_BIN="/opt/homebrew/bin/openclaw"
LAUNCHCTL_BIN="/bin/launchctl"
LSOF_BIN="/usr/sbin/lsof"
STAT_BIN="/usr/bin/stat"
TAIL_BIN="/usr/bin/tail"
DATE_BIN="/bin/date"
HOSTNAME_BIN="/bin/hostname"

GATEWAY_PORT="18789"
GATEWAY_BIND="lan"
GATEWAY_LOG="$HOME/.openclaw/logs/gateway.log"
GATEWAY_ERR_LOG="$HOME/.openclaw/logs/gateway.err.log"
CLI_FILE_LOG_DIR="/tmp/openclaw"

ADAPTER_BIN_DIR="$HOME/.openclaw/recovery/gateway-v04/bin"
RESULT_FILE="$HOME/.openclaw/recovery/gateway-v04/results/last-result.json"
EVENT_FILE="$HOME/.openclaw/recovery/gateway-v04/logs/recover-events.log"
ATTEMPT_LOG="$HOME/.openclaw/recovery/gateway-v04/logs/recover-attempts.log"
SAMPLES_DIR="$HOME/.openclaw/recovery/gateway-v04/samples"
LOCK_DIR="$HOME/.openclaw/recovery/gateway-v04/locks/recover.lock"

RECOVER_COOLDOWN_SECONDS="60"
RECOVER_MAX_RECENT_ATTEMPTS="3"
RECOVER_WINDOW_SECONDS="300"
RECOVER_LOCK_STALE_SECONDS="600"
RECOVER_LOG_TAIL_LINES="120"
